# FastAPI
APP_NAME=Atalaya FastAPI
API_PREFIX=/api/v1
CORS_ORIGINS=*

# PostgreSQL (Render/local)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=atalaya
DB_USER=postgres
DB_PASSWORD=CHANGE_ME
DB_SSLMODE=prefer

# Dashboard behavior
DASHBOARD_ALERT_LIMIT=25
STALE_THRESHOLD_SECONDS=10
SAMPLE_SLOT_COUNT=8

# Caches (seconds)
DASHBOARD_CACHE_TTL_SECONDS=2
ALERTS_CACHE_TTL_SECONDS=2
KP_STATE_CACHE_TTL_SECONDS=10
SAMPLE_TAG_EXISTENCE_CACHE_TTL_SECONDS=120

# Optional optimizations / security
LATEST_SAMPLES_SUMMARY_NAME=public.atalaya_latest_samples_mv
ATTACHMENT_TABLE_CANDIDATES=public.attachments,public.atalaya_attachments
ALLOWED_ATTACHMENT_HOSTS=

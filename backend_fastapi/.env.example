DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_SSLMODE=require
DB_CONNECT_TIMEOUT_SECONDS=10
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=300
STATEMENT_TIMEOUT_MS=5000
IDLE_IN_TRANSACTION_SESSION_TIMEOUT_MS=15000
DB_RETRY_ATTEMPTS=2
DB_RETRY_BACKOFF_MS=120
APP_WORKERS=1

CORS_ORIGINS=*
MAX_REQUEST_SIZE_BYTES=1048576
ENFORCE_HTTPS_IN_PROD=true
RATE_LIMIT_AUTH_MAX_REQUESTS=10
RATE_LIMIT_AUTH_WINDOW_SECONDS=60
RATE_LIMIT_SENSITIVE_MAX_REQUESTS=120
RATE_LIMIT_SENSITIVE_WINDOW_SECONDS=60
STALE_THRESHOLD_SECONDS=10
DASHBOARD_ALERT_LIMIT=25

AUTH_ENABLED=false
AUTH_SKIP_DB_INIT=false
APP_ENV=dev
AUTH_SECRET_KEY=change-me-before-prod
AUTH_SECRET_KEY_DEV=
AUTH_SECRET_KEY_STAGE=
AUTH_SECRET_KEY_PROD=
AUTH_COOKIE_NAME=atalaya_session
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_SESSION_TIMEOUT_HOURS=12
AUTH_PASSWORD_MIN_LENGTH=12
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_LOCKOUT_MINUTES=15
AUTH_BANNED_PASSWORDS=password,123456,123456789,qwerty,admin,letmein
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=
AUTH_DB_INIT_MAX_RETRIES=3
AUTH_DB_INIT_RETRY_DELAY_SECONDS=1.5
